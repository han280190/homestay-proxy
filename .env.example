# Vercel Environment Variables
# Copy này vào Vercel Dashboard → Settings → Environment Variables

# Apps Script Web App URL (lấy từ deployed Apps Script)
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_SCRIPT_ID/userweb

# API Secret Key - dùng để verify request từ proxy tới backend
# 32 ký tự random (tôi đã sinh): a7f3k9b2m1x5q8w6j4c7d9e2h5t3r1u0
API_SECRET_KEY=a7f3k9b2m1x5q8w6j4c7d9e2h5t3r1u0

# Google Sheets ID (dùng cho audit log)
# Lấy từ URL: https://docs.google.com/spreadsheets/d/SHEET_ID/edit
AUDIT_SHEET_ID=your-google-sheet-id-here

# Vercel KV Store (tùy chọn, để trống nếu dùng in-memory)
# KV_URL=

# Node environment
NODE_ENV=production
